.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 168rpx;
}

.about-hero {
  margin-bottom: 22rpx;
}

.about-content {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: #4f5953;
  margin-bottom: 24rpx;
}

.contact-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.contact-row {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(221, 216, 204, 0.6);
}

.contact-label {
  width: 132rpx;
  font-size: 24rpx;
  color: #8a918c;
}

.contact-value {
  flex: 1;
  font-size: 24rpx;
  color: #1f2320;
}

.tab-bar {
  display: flex;
  padding: 8rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 252, 247, 0.92);
  border-radius: 999rpx;
  border: 1rpx solid rgba(221, 216, 204, 0.9);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 12rpx;
  font-size: 26rpx;
  color: #66706a;
  font-weight: 600;
  border-radius: 999rpx;
}

.tab.active {
  color: #fffcf7;
  background: #2f6b57;
  box-shadow: 0 8rpx 18rpx rgba(47, 107, 87, 0.16);
}

.content-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.content-card {
  display: flex;
  background: #fffcf7;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(221, 216, 204, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 32, 0.08);
}

.content-cover {
  width: 220rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.content-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.content-title {
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #1f2320;
  margin-bottom: 10rpx;
}

.content-summary {
  font-size: 24rpx;
  line-height: 1.6;
  color: #66706a;
  flex: 1;
  margin-bottom: 12rpx;
}

.content-meta {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.content-date {
  font-size: 22rpx;
  color: #8a918c;
}

.content-category {
  font-size: 22rpx;
  color: #2f6b57;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 87, 0.08);
}

.load-more {
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.load-more-text {
  min-width: 200rpx;
}

.admin-section {
  display: flex;
  justify-content: center;
  padding-top: 28rpx;
}

.admin-entry-btn {
  padding: 8rpx 16rpx;
}

.admin-hint {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: rgba(102, 112, 106, 0.32);
}
