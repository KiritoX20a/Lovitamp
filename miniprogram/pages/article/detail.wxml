<view class="page">
  <image class="cover" src="{{article.coverImageUrl||article.coverImage}}" mode="widthFix" wx:if="{{(article.coverImageUrl||article.coverImage)&&article.type==='blog'}}"></image>
  <video class="video-player" src="{{article.videoUrl||article.content}}" controls="{{true}}" wx:if="{{article.type==='vlog'}}" />
  <view class="article-header" wx:if="{{article.type==='blog'}}">
    <text class="title">{{article.title}}</text>
    <view class="meta">
      <text class="date">{{formatDate(article.publishDate)}}</text>
      <text class="tag" wx:for="{{article.tags}}" wx:key="index">{{item}}</text>
    </view>
  </view>
  <rich-text class="content" nodes="{{renderedContent}}" wx:if="{{article.type==='blog'}}"></rich-text>
</view>
