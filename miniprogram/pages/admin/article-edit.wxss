.page { min-height:100vh; background:#f6f4ee; }
.form { padding:30rpx; }
.form-group { margin-bottom:30rpx; }
.label { font-size:28rpx; color:#1f2320; font-weight:600; margin-bottom:12rpx; display:block; }
.input { width:100%; height:80rpx; padding:0 20rpx; background:#fffcf7; border-radius:18rpx; font-size:28rpx; box-sizing:border-box; border:1rpx solid rgba(221,216,204,0.9); }
.textarea { width:100%; height:160rpx; padding:20rpx; background:#fffcf7; border-radius:18rpx; font-size:28rpx; box-sizing:border-box; border:1rpx solid rgba(221,216,204,0.9); }
.content-input { height:400rpx; }
.picker { width:100%; height:80rpx; line-height:80rpx; padding:0 20rpx; background:#fffcf7; border-radius:18rpx; font-size:28rpx; color:#1f2320; box-sizing:border-box; border:1rpx solid rgba(221,216,204,0.9); }
.cover-picker { width:200rpx; height:200rpx; background:#fffcf7; border-radius:18rpx; display:flex; align-items:center; justify-content:center; overflow:hidden; border:1rpx solid rgba(221,216,204,0.9); }
.cover-preview { width:100%; height:100%; }
.cover-placeholder { font-size:24rpx; color:#8a918c; }
.form-actions { display:flex; gap:20rpx; margin-top:40rpx; align-items:center; }
