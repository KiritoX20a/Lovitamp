.page { min-height:100vh; background:#f6f4ee; }
.header-bar { display:flex; justify-content:space-between; align-items:center; padding:30rpx; }
.header-title { font-size:36rpx; font-weight:700; color:#1f2320; }
.media-grid { padding:0 30rpx; }
.media-card { display:flex; align-items:center; background:#fffcf7; border-radius:20rpx; padding:20rpx; margin-bottom:16rpx; box-shadow:0 8rpx 24rpx rgba(31,35,32,0.08); border:1rpx solid rgba(221,216,204,0.8); }
.media-thumb { width:120rpx; height:120rpx; border-radius:14rpx; flex-shrink:0; }
.media-info { flex:1; padding:0 20rpx; }
.media-title { font-size:26rpx; color:#1f2320; display:block; margin-bottom:4rpx; font-weight:600; }
.media-type { font-size:22rpx; color:#8a918c; }
.media-actions { display:flex; gap:12rpx; }
.action-btn { min-width:120rpx; }
