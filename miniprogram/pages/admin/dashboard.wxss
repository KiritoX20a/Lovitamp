.page { min-height:100vh; background:#f6f4ee; }
.header { padding:40rpx 30rpx; background:linear-gradient(135deg,#315f51,#486b4f); color:#fffcf7; }
.header-title { font-size:40rpx; font-weight:700; display:block; }
.header-subtitle { font-size:26rpx; color:rgba(255,252,247,0.76); margin-top:8rpx; display:block; }
.stats-grid { display:flex; gap:20rpx; padding:30rpx; }
.stat-card { flex:1; background:#fffcf7; border-radius:20rpx; padding:30rpx 20rpx; text-align:center; box-shadow:0 8rpx 24rpx rgba(31,35,32,0.08); border:1rpx solid rgba(221,216,204,0.8); }
.stat-number { font-size:48rpx; font-weight:700; color:#2f6b57; display:block; }
.stat-label { font-size:24rpx; color:#8a918c; margin-top:8rpx; display:block; }
.quick-actions { display:flex; gap:20rpx; padding:0 30rpx 30rpx; }
.action-item { flex:1; background:#fffcf7; border-radius:20rpx; padding:30rpx; text-align:center; box-shadow:0 8rpx 24rpx rgba(31,35,32,0.08); border:1rpx solid rgba(221,216,204,0.8); }
.action-icon { font-size:48rpx; display:block; margin-bottom:8rpx; }
.action-text { font-size:26rpx; color:#1f2320; }
.section { padding:0 30rpx 30rpx; }
.section-title { font-size:32rpx; font-weight:700; color:#1f2320; margin-bottom:20rpx; display:block; }
.recent-item { display:flex; justify-content:space-between; align-items:center; background:#fffcf7; padding:20rpx; border-radius:16rpx; margin-bottom:12rpx; border:1rpx solid rgba(221,216,204,0.8); }
.recent-title { font-size:26rpx; color:#1f2320; flex:1; }
.recent-date { font-size:22rpx; color:#8a918c; }
