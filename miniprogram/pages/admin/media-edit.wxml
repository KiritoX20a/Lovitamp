<view class="page">
  <view class="header-bar"><text class="header-title">媒体管理</text><button class="btn-primary btn-compact upload-btn" bindtap="uploadMedia">上传</button></view>
  <view class="media-grid">
    <view wx:for="{{mediaList}}" wx:key="_id" class="media-card">
      <image class="media-thumb" src="{{item.thumbnailUrl||item.urlTemp||item.thumbnail||item.url}}" mode="aspectFill"></image>
      <view class="media-info"><text class="media-title">{{item.title||"未命名"}}</text><text class="media-type">{{item.type==="image"?"图片":"视频"}}</text></view>
      <view class="media-actions">
        <button class="btn-tertiary btn-compact action-btn" bindtap="editMedia" data-id="{{item._id}}">编辑</button>
        <button class="btn-danger btn-compact action-btn delete" bindtap="deleteMedia" data-id="{{item._id}}" data-fileid="{{item.url}}">删除</button>
      </view>
    </view>
  </view>
</view>
