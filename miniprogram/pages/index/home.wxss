.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 168rpx;
}

.hero-card {
  padding: 36rpx;
  border-radius: 32rpx;
  background:
    linear-gradient(135deg, rgba(255, 252, 247, 0.98), rgba(248, 243, 233, 0.96));
  border: 1rpx solid rgba(221, 216, 204, 0.8);
  box-shadow: 0 12rpx 32rpx rgba(31, 35, 32, 0.08);
  margin-bottom: 28rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.hero-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hero-tag {
  display: inline-block;
  margin-bottom: 14rpx;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #66706a;
}

.avatar-container {
  width: 148rpx;
  height: 148rpx;
  border-radius: 40rpx;
  overflow: hidden;
  background: rgba(47, 107, 87, 0.12);
  border: 4rpx solid rgba(255, 252, 247, 0.92);
  box-shadow: 0 8rpx 18rpx rgba(47, 107, 87, 0.12);
}

.avatar {
  width: 100%;
  height: 100%;
}

.nickname {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1f2320;
  margin-bottom: 10rpx;
}

.bio {
  font-size: 26rpx;
  line-height: 1.7;
  color: #66706a;
}

.hero-actions {
  margin-top: 30rpx;
}

.social-links {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-top: 22rpx;
}

.social-tag {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 87, 0.08);
  border: 1rpx solid rgba(47, 107, 87, 0.1);
  font-size: 22rpx;
  color: #2f6b57;
}

.feature-media {
  margin-bottom: 16rpx;
}

.swiper {
  width: 100%;
  height: 360rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 26rpx rgba(31, 35, 32, 0.08);
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.section {
  padding-top: 8rpx;
}

.section-more {
  flex-shrink: 0;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.article-card {
  display: flex;
  background: #fffcf7;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(221, 216, 204, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 32, 0.08);
}

.article-cover {
  width: 216rpx;
  height: 176rpx;
  flex-shrink: 0;
}

.article-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-meta-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.article-type {
  color: #2f6b57;
}

.article-title {
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #1f2320;
  margin-bottom: 10rpx;
}

.article-summary {
  font-size: 24rpx;
  line-height: 1.6;
  color: #66706a;
}

.article-date {
  font-size: 22rpx;
  color: #8a918c;
}
