.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 168rpx;
}

.header {
  margin-bottom: 28rpx;
  padding: 36rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #315f51, #486b4f);
  color: #fffcf7;
  box-shadow: 0 12rpx 28rpx rgba(47, 107, 87, 0.18);
}

.header-title {
  font-size: 42rpx;
  font-weight: 700;
}

.header-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 252, 247, 0.8);
}

.category-section {
  margin-bottom: 26rpx;
}

.category-header {
  margin-bottom: 16rpx;
}

.category-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2320;
}

.skill-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.skill-card {
  background: #fffcf7;
  border-radius: 24rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(221, 216, 204, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 32, 0.08);
}

.skill-top {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.skill-icon-wrap {
  flex-shrink: 0;
}

.skill-icon {
  font-size: 30rpx;
  line-height: 1;
}

.skill-copy {
  flex: 1;
}

.skill-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2320;
  margin-bottom: 8rpx;
}

.skill-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: #66706a;
}

.skill-level {
  display: flex;
  gap: 8rpx;
}

.level-bar {
  flex: 1;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 87, 0.12);
}

.level-bar.active {
  background: #2f6b57;
}
