<view class="page-shell">
  <view class="page">
    <view class="header">
      <text class="header-title">技能图谱</text>
      <text class="header-desc">把热爱、专业能力和长期积累放在同一张地图里。</text>
    </view>
    <view wx:for="{{skillCategories}}" wx:key="name" class="category-section">
      <view class="category-header">
        <text class="category-name">{{item.name}}</text>
      </view>
      <view class="skill-list">
        <view wx:for="{{item.skills}}" wx:key="_id" class="skill-card">
          <view class="skill-top">
            <view class="icon-badge skill-icon-wrap">
              <text class="skill-icon" wx:if="{{item.icon}}">{{item.icon}}</text>
              <text class="skill-icon" wx:else>技</text>
            </view>
            <view class="skill-copy">
              <text class="skill-name">{{item.name}}</text>
              <text class="skill-desc" wx:if="{{item.description}}">{{item.description}}</text>
            </view>
          </view>
          <view class="skill-level">
            <view wx:for="{{[1,2,3,4,5]}}" wx:key="index" class="level-bar {{index < item.level ? 'active' : ''}}"></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
