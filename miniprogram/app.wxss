page {
  font-family: "Avenir Next", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  background-color: #f6f4ee;
  color: #1f2320;
  box-sizing: border-box;
}

view,
text,
navigator,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(201, 111, 74, 0.08), transparent 26%),
    linear-gradient(180deg, #fbf9f4 0%, #f6f4ee 100%);
}

.tone-soft {
  color: #66706a;
}

.tone-muted {
  color: #8a918c;
}

.tone-accent {
  color: #2f6b57;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fffcf7;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(221, 216, 204, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 32, 0.08);
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2320;
}

.section-note {
  font-size: 24rpx;
  color: #66706a;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #66706a;
  background: rgba(47, 107, 87, 0.08);
  border: 1rpx solid rgba(47, 107, 87, 0.1);
}

.button-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.btn,
.btn-primary,
.btn-secondary,
.btn-tertiary,
.btn-danger,
.btn-chip {
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.btn {
  color: #1f2320;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid rgba(221, 216, 204, 0.9);
}

.btn-primary {
  color: #fffcf7;
  background: linear-gradient(135deg, #2f6b57, #3d7c67);
  box-shadow: 0 10rpx 22rpx rgba(47, 107, 87, 0.18);
}

.btn-secondary {
  color: #2f6b57;
  background: rgba(255, 252, 247, 0.88);
  border: 1rpx solid rgba(47, 107, 87, 0.18);
}

.btn-tertiary {
  color: #66706a;
  background: rgba(255, 252, 247, 0.82);
  border: 1rpx solid rgba(221, 216, 204, 0.9);
}

.btn-danger {
  color: #fff7f5;
  background: linear-gradient(135deg, #c96f4a, #b85f3d);
  box-shadow: 0 10rpx 22rpx rgba(201, 111, 74, 0.18);
}

.btn-chip {
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #66706a;
  background: rgba(255, 252, 247, 0.9);
  border: 1rpx solid rgba(221, 216, 204, 0.9);
}

.btn-chip-active {
  color: #fffcf7;
  background: #2f6b57;
  border-color: #2f6b57;
}

.btn-compact {
  height: 64rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.btn-block {
  width: 100%;
}

.btn-text {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #2f6b57;
}

.btn-text-muted {
  color: #66706a;
}

.icon-badge {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(47, 107, 87, 0.1);
  color: #2f6b57;
  font-size: 34rpx;
  font-weight: 600;
}
