.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0 18rpx calc(env(safe-area-inset-bottom) + 18rpx);
  z-index: 999;
  pointer-events: none;
}

.tabbar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 0 auto;
  padding: 12rpx;
  border-radius: 36rpx;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid rgba(221, 216, 204, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(31, 35, 32, 0.12);
  backdrop-filter: blur(20rpx);
  pointer-events: auto;
}

.tab-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 10rpx 6rpx;
  border-radius: 28rpx;
  transition: all 180ms ease;
}

.tab-item-active {
  background: linear-gradient(135deg, rgba(47, 107, 87, 0.12), rgba(61, 124, 103, 0.18));
}

.tab-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: rgba(246, 244, 238, 0.8);
}

.tab-icon-wrap-active {
  background: linear-gradient(135deg, #2f6b57, #3d7c67);
  box-shadow: 0 10rpx 20rpx rgba(47, 107, 87, 0.18);
}

.tab-icon {
  width: 38rpx;
  height: 38rpx;
}

.tab-label {
  max-width: 100%;
  font-size: 20rpx;
  line-height: 1.2;
  color: #8a918c;
  text-align: center;
}

.tab-label-active {
  color: #2f6b57;
  font-weight: 700;
}
